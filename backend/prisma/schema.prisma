datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  nickname  String?
  createdAt DateTime @default(now())

  sessions AssessmentSession[]
}

model Scenario {
  id                String   @id
  title             String
  description       String
  backgroundForUser String
  openingMessageJson String?
  initialBlackboardJson String?
  maxRound          Int      @default(8)
  groupChatEnabled  Boolean  @default(true)
  groupChatRounds   String   @default("[3,6]")
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions AssessmentSession[]
}

model PromptTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  content   String
  version   Int      @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessmentSession {
  id               String    @id @default(cuid())
  userId           String?
  scenarioId       String
  status           String    @default("running")
  round            Int       @default(0)
  blackboardState  String
  totalScore       Int?
  reportJson       String?
  groupChatSummary String?
  startedAt        DateTime  @default(now())
  endedAt          DateTime?

  user             User?     @relation(fields: [userId], references: [id])
  scenario         Scenario  @relation(fields: [scenarioId], references: [id])
  messages         Message[]
  groupDiscussions AgentGroupDiscussion[]

  @@index([scenarioId])
  @@index([userId])
  @@index([status])
}

model Message {
  id          String   @id @default(cuid())
  sessionId   String
  senderType  String
  senderName  String
  senderRole  String?
  content     String
  roundIndex  Int
  createdAt   DateTime @default(now())

  session     AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, roundIndex])
}

model AgentGroupDiscussion {
  id          String   @id @default(cuid())
  sessionId   String
  roundIndex  Int
  phase       String
  inputJson   String
  outputJson  String
  createdAt   DateTime @default(now())

  session     AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, roundIndex])
}
