{
  "name": "workplace-survival-capsule",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "backend:dev": "npm run dev -w backend",
    "backend:start": "npm run start -w backend",
    "frontend:dev": "npm run dev -w frontend",
    "backend:build": "npm run build -w backend",
    "frontend:build": "npm run build -w frontend",
    "test": "npm run test -w backend"
  }
}
